{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Windows PDF Directory Explorer",
  "version": "0.1.0",
  "identifier": "com.omx.windowspdfdir",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Windows PDF Directory Explorer",
        "width": 1480,
        "height": 860,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": []
  }
}
